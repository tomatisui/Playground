generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ScreeningSession {
  id                   String                  @id @default(cuid())
  childLabel           String
  ageYears             Int
  classroomLabel       String?
  guardianName         String?
  guardianPhone        String
  guardianRelationship String?
  birthYear            Int?
  birthMonth           Int?
  birthDay             Int?
  consentAcceptedAt    DateTime?
  audioCheckPassed     Boolean?
  audioCheckCompletedAt DateTime?
  currentRoute         String?
  currentModuleCode    String?
  lastActiveAt         DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  moduleAttempts       ScreeningModuleAttempt[]
  qualityFlags         ScreeningQualityFlag[]
}

model ScreeningModuleAttempt {
  id                  String           @id @default(cuid())
  sessionId           String
  moduleCode          String
  status              String           @default("NOT_STARTED")
  startedAt           DateTime?
  completedAt         DateTime?
  practiceRuns        Int              @default(0)
  practiceFailures    Int              @default(0)
  lastItemIndex       Int              @default(0)
  correctCount        Int              @default(0)
  itemCount           Int              @default(0)
  caregiverAssistCount Int             @default(0)
  provisionalSummary  String?
  responseLog         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  session             ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, moduleCode])
}

model ScreeningQualityFlag {
  id        String           @id @default(cuid())
  sessionId String
  flagCode  String
  note      String?
  createdAt DateTime         @default(now())
  session   ScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, flagCode])
}
